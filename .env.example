# PostgreSQL credentials (used by docker-compose.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=antenna

# Application database connection (must match the credentials above)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/antenna

# Port the app container exposes on the host (default: 3000)
PORT=3000

# Public site URL used for absolute metadata links (Open Graph/Twitter)
VITE_SITE_URL=http://localhost:3000
